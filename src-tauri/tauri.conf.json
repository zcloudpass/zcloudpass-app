{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "zCloudPass",
  "version": "0.1.0",
  "identifier": "com.zcloudpass.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "zCloudPass",
        "label": "main",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://zcloudpass-backend.onrender.com; img-src 'self' https://www.google.com data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Secure password manager",
    "longDescription": "zCloudPass - A secure, encrypted cloud password manager with biometric unlock support."
  },
  "plugins": {
    "biometric": {
      "reason": "Unlock your vault securely with biometric authentication"
    }
  }
}
